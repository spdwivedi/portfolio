<% /* * FILE DETAILS: Portfolio Project Card Partial Component
 * -----------------------------------------------------
 * This sub-component renders individual item states inside the main projects loop.
 * Refactored to leverage your new hardware-accelerated theme matrix:
 * 1. Streamlined Inline Styles: Stripped out static inline layout overrides that were 
 * blocking high-priority layout animations inside your stylesheet.
 * 2. Dynamic Accent Inheritance: The folder icon and tech pills automatically track 
 * var(--accent-primary), matching your page-wide aura shifts on hover.
 */ %>

<div class="card">
    
    <header style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
        <div class="folder-icon">
            <i class="fa-regular fa-folder" style="font-size: 2.3rem; color: var(--accent-primary); transition: color 0.3s ease;"></i>
        </div>
        
        <div class="project-links">
            <% if (project.links) { %>
                
                <% if (project.links.github) { %>
                    <a href="<%= project.links.github %>" target="_blank" rel="noopener noreferrer" aria-label="View Code on GitHub">
                        <i class="fa-brands fa-github" title="View Code Base"></i>
                    </a>
                <% } %>
                
                <% if (project.links.liveUrl) { %>
                    <a href="<%= project.links.liveUrl %>" target="_blank" rel="noopener noreferrer" aria-label="View Live Deployment">
                        <i class="fa-solid fa-external-link-alt" title="Live Demo App"></i>
                    </a>
                <% } %>
                
                <% if (project.links.datasetUrl) { %>
                    <a href="<%= project.links.datasetUrl %>" target="_blank" rel="noopener noreferrer" aria-label="View Project Dataset">
                        <i class="fa-brands fa-google-drive" title="View Dataset Link"></i>
                    </a>
                <% } %>
                
            <% } %>
        </div>
    </header>

    <h3 class="project-title">
        <%= project.title %>
    </h3>

    <div class="project-description" style="flex-grow: 1; margin-bottom: 20px;">
        <p style="font-size: 0.95rem; line-height: 1.6; margin: 0;">
            <%= project.description %>
        </p>
    </div>

    <footer>
        <ul style="list-style: none; display: flex; flex-wrap: wrap; gap: 8px; padding: 0; margin: 0;">
            <% if (project.tags && project.tags.length > 0) { %>
                <% project.tags.forEach(tag => { %>
                    <li class="tech-tag"><%= tag %></li>
                <% }) %>
            <% } else if (project.tech && project.tech.length > 0) { %>
                <% project.tech.forEach(tech => { %>
                    <li class="tech-tag"><%= tech %></li>
                <% }) %>
            <% } %>
        </ul>
    </footer>

</div>

<style>
    /* Scope card link interaction physics cleanly */
    .project-links { display: flex; gap: 16px; }
    .project-links a { display: inline-block; color: var(--text-muted); }
    .project-links a:hover { color: var(--accent-primary) !important; transform: translateY(-3px); }
    .project-links i { font-size: 1.25rem; transition: transform 0.25s ease, color 0.25s ease; }
</style>