<%- include('../partials/header') %>

<section class="container" style="padding-top: 120px; padding-bottom: 100px;">
    
    <div style="text-align: center; margin-bottom: 60px;">
        <p class="intro-mono" data-aos="fade-down" style="color: var(--accent-primary);">03. Continuous Learning</p>
        <h1 data-aos="fade-up">My <span class="highlight">Certifications</span></h1>
        <p data-aos="fade-up" data-aos-delay="100" style="margin: 20px auto; max-width: 600px;">
            A collection of courses I've completed to stay sharp. <br>
            <span style="font-size: 0.9rem; color: var(--accent-primary);">Total Count: <span id="cert-count">0</span> Verified</span>
        </p>
    </div>

    <div class="search-wrapper" data-aos="fade-up" data-aos-delay="200" style="margin-bottom: 40px; display: flex; justify-content: center;">
        <input type="text" id="searchInput" placeholder="Search by course name, technology, or platform..." 
               style="width: 100%; max-width: 500px; padding: 15px; border-radius: 8px; border: 1px solid var(--glass-border); background: var(--bg-card); color: var(--text-main); outline: none;">
    </div>

    <div class="table-container" data-aos="fade-up" data-aos-delay="300" style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
            <thead>
                <tr style="text-align: left; border-bottom: 1px solid var(--glass-border);">
                    <th style="padding: 15px; color: var(--accent-primary); font-family: var(--font-heading); font-size: 1.05rem;">Course Title</th>
                    <th style="padding: 15px; color: var(--accent-primary); font-family: var(--font-heading); font-size: 1.05rem;">Platform</th>
                    <th style="padding: 15px; color: var(--accent-primary); font-family: var(--font-heading); font-size: 1.05rem;">Year</th>
                    <th style="padding: 15px; text-align: right; color: var(--accent-primary); font-family: var(--font-heading); font-size: 1.05rem;">Verify</th>
                </tr>
            </thead>
            <tbody id="certTableBody">
                </tbody>
        </table>
    </div>

    <div style="margin-top: 40px; text-align: center; display: flex; justify-content: center; align-items: center; gap: 15px;">
        <button id="prevBtn" class="btn btn-primary" style="padding: 8px 18px; font-size: 0.85rem; font-family: var(--font-mono);" disabled>Previous</button>
        <span id="pageIndicator" style="font-family: var(--font-mono); font-size: 0.9rem; color: var(--text-muted);">Page 1</span>
        <button id="nextBtn" class="btn btn-primary" style="padding: 8px 18px; font-size: 0.85rem; font-family: var(--font-mono);">Next</button>
    </div>

</section>

<script>
    let allCerts = [];
    let filteredCerts = [];
    let currentPage = 1;
    const itemsPerPage = 20;

    const tableBody = document.getElementById('certTableBody');
    const searchInput = document.getElementById('searchInput');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const pageIndicator = document.getElementById('pageIndicator');

    // Asynchronously stream dynamic data from your unified MongoDB endpoints
    fetch('/api/certificates')
        .then(response => {
            if (!response.ok) throw new Error("Database query connectivity stream issue.");
            return response.json();
        })
        .then(data => {
            allCerts = data;
            filteredCerts = [...allCerts]; // Populate baseline replication data array
            document.getElementById('cert-count').innerText = allCerts.length;
            renderTable(filteredCerts);
        })
        .catch(error => {
            console.error('Critical crash harvesting Dynamic Certifications assets:', error);
            tableBody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding: 30px; color: var(--accent-secondary);">Failed to pull real-time database credentials. Please refresh later.</td></tr>';
        });

    // Unified layout paint compiler mapping to your Mongoose document properties
    function renderTable(data) {
        tableBody.innerHTML = '';
        
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const pageData = data.slice(start, end);

        if (pageData.length === 0) {
            tableBody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding: 30px; color: var(--text-muted); font-style: italic;">No verified credentials match your filter query string.</td></tr>';
            pageIndicator.innerText = `Page 0 of 0`;
            prevBtn.disabled = true;
            nextBtn.disabled = true;
            return;
        }

        pageData.forEach(cert => {
            const row = `
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.04); transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.01)'" onmouseout="this.style.backgroundColor='transparent'">
                    <td style="padding: 18px 15px; font-weight: 500; color: var(--text-main); font-size: 1rem;">${cert.title}</td>
                    <td style="padding: 18px 15px; color: var(--text-muted); font-size: 0.95rem;">${cert.platform}</td>
                    <td style="padding: 18px 15px; font-family: var(--font-mono); font-size: 0.9rem; color: var(--accent-primary);">${cert.year}</td>
                    <td style="padding: 18px 15px; text-align: right;">
                        <a href="${cert.verifyUrl}" target="_blank" rel="noopener noreferrer" style="color: var(--text-muted); transition: color 0.3s;" onmouseover="this.style.color='var(--accent-primary)'" onmouseout="this.style.color='var(--text-muted)'" aria-label="Verify Certificate">
                            <i class="fa-solid fa-arrow-up-right-from-square" style="font-size: 1.05rem;"></i>
                        </a>
                    </td>
                </tr>
            `;
            tableBody.innerHTML += row;
        });

        // Toggle state properties on control nodes
        const totalPages = Math.ceil(data.length / itemsPerPage) || 1;
        pageIndicator.innerText = `Page ${currentPage} of ${totalPages}`;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = end >= data.length;
    }

    // High-performance structural string token matching filters
    searchInput.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase().trim();
        
        filteredCerts = allCerts.filter(cert => 
            cert.title.toLowerCase().includes(term) || 
            cert.platform.toLowerCase().includes(term) ||
            cert.year.toString().includes(term)
        );
        
        currentPage = 1; // Direct jump back to origin grid matrix on structural change
        renderTable(filteredCerts);
    });

    // Absolute pagination navigation drivers
    prevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
            currentPage--;
            renderTable(filteredCerts);
        }
    });

    nextBtn.addEventListener('click', () => {
        if ((currentPage * itemsPerPage) < filteredCerts.length) {
            currentPage++;
            renderTable(filteredCerts);
        }
    });
</script>

<%- include('../partials/footer') %>