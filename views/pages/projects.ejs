/**
 * FILE DETAILS: Portfolio Projects View Layout Template
 * -----------------------------------------------------
 * This file constructs the user interface for the 'Work' page.
 * To ensure complete IDE compatibility and zero linter validation errors:
 * 1. It utilizes a clean configuration loop array instead of raw JavaScript functions.
 * 2. It evaluates layout spacing properties dynamically inside an EJS string wrapper,
 * preventing the VS Code CSS engine from throwing 'css-rcurlyexpected' false positives.
 * 3. It filters backend data sets retrieved from MongoDB to distribute projects into structural grid rows.
 */

<%- include('../partials/header') %>

<section class="container" style="padding-top: 120px; padding-bottom: 100px;">
    
    <div style="text-align: center; margin-bottom: 80px;">
        <p class="intro-mono" data-aos="fade-down" style="color: var(--accent-primary);">02. My Portfolio</p>
        <h1 data-aos="fade-up">My <span class="highlight">Work</span></h1>
    </div>

    <% 
      // 1. Define category configurations in a clean array to bypass HTML parsing conflicts
      const sections = [
        { title: 'College Projects', icon: 'fa-solid fa-graduation-cap', key: 'college' },
        { title: 'Personal Projects', icon: 'fa-solid fa-user-astronaut', key: 'personal' },
        { title: 'Udemy Projects', icon: 'fa-solid fa-video', key: 'udemy' },
        { title: 'Coursera Projects', icon: 'fa-solid fa-certificate', key: 'coursera' }
      ];
    %>

    <% // 2. Loop through the structural sections sequentially %>
    <% sections.forEach(section => { %>
        <div class="project-category" style="margin-bottom: 100px;">
            
            <h2 class="category-title" data-aos="fade-right" style="font-size: 1.8rem; margin-bottom: 30px; border-bottom: 1px solid var(--glass-border); padding-bottom: 10px; display: inline-block;">
                <i class="<%= section.icon %>" style="color: var(--accent-primary); margin-right: 10px;"></i> <%= section.title %>
            </h2>
            
            <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; grid-auto-flow: dense;">
                <% 
                   // Filter records matching current category context strings
                   const filtered = projects.filter(p => p.category === section.key || p.category.toLowerCase().includes(section.key.toLowerCase())); 
                %>
                
                <% if(filtered.length > 0) { %>
                    <% filtered.forEach((project, index) => { 
                        const size = project.layout?.size || 'normal';
                        let cssRules = "";
                        
                        // Assemble the exact CSS grid rules strings based on sizing metadata blueprints
                        if (size === 'wide-block') cssRules = "grid-column: span 2;";
                        else if (size === 'tall-block') cssRules = "grid-row: span 2;";
                        else if (size === 'large-block') cssRules = "grid-column: span 2; grid-row: span 2;";
                    %>
                        <div class="studio-grid-item size-<%= size %>" 
                             data-aos="fade-up" 
                             data-aos-delay="<%= index * 50 %>"
                             <%= cssRules ? `style="${cssRules}"` : '' %>>
                             
                            <%- include('../partials/project-card', { project: project }) %>
                            
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column: 1 / -1; padding: 40px; text-align: center; border: 1px dashed var(--glass-border); border-radius: 12px;">
                        <p style="color: var(--text-muted); font-style: italic; margin: 0;">Adding engineering records soon...</p>
                    </div>
                <% } %>
            </div>
        </div>
    <% }); %>

</section>

<%- include('../partials/footer') %>