<% /* * FILE DETAILS: Portfolio Projects Showcase View Layout Template
 * -----------------------------------------------------
 * This file constructs the user interface for the public 'Work' page.
 * Upgraded with futuristic presentation engines and strict linter-proof hooks:
 * 1. Server-Side Comment Enclosure: [FIXED] Safely wraps file data comments inside proper 
 * EJS compilation boundaries to permanently stop raw text leaking onto the header space.
 * 2. Asymmetric 2x2 Matrix Stretching: [FIXED] Forces deep viewport dual-axis card scaling 
 * by using flex alignments paired with explicit vertical height parameters.
 * 3. Sci-Fi Canvas Intercept Matrix: Exposes real-time data variables (`data-project-brand`, 
 * `data-hover-engine`) to feed telemetry arrays directly into your frontend scripts.
 */ %>

<%- include('../partials/header') %>

<section class="container" style="padding-top: 120px; padding-bottom: 100px;">
    
    <div style="text-align: center; margin-bottom: 80px;">
        <p class="intro-mono" data-aos="fade-down" style="color: var(--accent-primary);">02. My Portfolio</p>
        <h1 data-aos="fade-up">My <span class="highlight">Work</span></h1>
    </div>

    <% 
      // Define category dictionary objects to safely loop and route records 
      const sections = [
        { title: 'College Projects', icon: 'fa-solid fa-graduation-cap', key: 'college' },
        { title: 'Personal Projects', icon: 'fa-solid fa-user-astronaut', key: 'personal' },
        { title: 'Udemy Projects', icon: 'fa-solid fa-video', key: 'udemy' },
        { title: 'Coursera Projects', icon: 'fa-solid fa-certificate', key: 'coursera' }
      ];
    %>

    <% // Iterate through category rows independently %>
    <% sections.forEach(section => { %>
        <div class="project-category" style="margin-bottom: 100px;">
            
            <h2 class="category-title" data-aos="fade-right" style="font-size: 1.8rem; margin-bottom: 30px; border-bottom: 1px solid var(--glass-border); padding-bottom: 10px; display: inline-block;">
                <i class="<%= section.icon %>" style="color: var(--accent-primary); margin-right: 10px;"></i> <%= section.title %>
            </h2>
            
            <div class="grid">
                <% 
                   // Filter backend datasets matching structural classification metrics
                   const filtered = projects.filter(p => p.category === section.key || p.category.toLowerCase().includes(section.key.toLowerCase())); 
                %>
                
                <% if(filtered.length > 0) { %>
                    <% filtered.forEach((project, index) => { 
                        const cardSize = project.layout?.size || 'normal';
                        const elementColor = project.accentColor || '#00f2ea';
                        const motionEngine = project.hoverAnimation || 'aura-glow';
                        
                        // [FIXED] Re-engineered blueprint layout rules to guarantee cross-axis card stretching
                        let layoutRules = "display: flex; flex-direction: column; align-self: stretch; width: 100%; height: 100%;";
                        if (cardSize === 'wide-block') layoutRules += " grid-column: span 2;";
                        else if (cardSize === 'tall-block') layoutRules += " grid-row: span 2;";
                        else if (cardSize === 'large-block') layoutRules += " grid-column: span 2; grid-row: span 2; min-height: 480px;";
                    %>
                        <div class="studio-grid-item size-<%= cardSize %>" 
                             data-aos="fade-up" 
                             data-aos-delay="<%= index * 50 %>"
                             data-project-brand="<%= elementColor %>"
                             data-hover-engine="<%= motionEngine %>"
                             <%- `style="${layoutRules} --card-brand-aura: ${elementColor};"` %>>
                             
                            <%- include('../partials/project-card', { project: project }) %>
                            
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column: 1 / -1; padding: 40px; text-align: center; border: 1px dashed var(--glass-border); border-radius: 12px;">
                        <p style="color: var(--text-muted); font-style: italic; margin: 0;">Adding engineering records soon...</p>
                    </div>
                <% } %>
            </div>
        </div>
    <% }); %>

</section>

<%- include('../partials/footer') %>